# Copy to .env and adjust. Never commit a real .env (it is gitignored).
# This is a local MVP/demo — do NOT use real patient data.

# --- Postgres (pgvector) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=recovery

# Consumed by the API container; defaults target the docker-compose `db` host.
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/recovery

# --- Redis (Celery/RQ broker + cache) ---
REDIS_URL=redis://redis:6379/0

# --- App ---
ENVIRONMENT=development

# --- LLM / embeddings ---
# Leave LLM_PROVIDER=mock (and key empty) to run fully offline with
# deterministic mock outputs. No real provider is required for the MVP.
LLM_PROVIDER=mock
LLM_API_KEY=
EMBEDDINGS_PROVIDER=mock

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
